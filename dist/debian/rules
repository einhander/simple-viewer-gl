#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DEB_CFLAGS_MAINT_APPEND = -fdebug-prefix-map=$(CURDIR)=.
export DEB_CXXFLAGS_MAINT_APPEND = -fdebug-prefix-map=$(CURDIR)=.

%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DAPP_VERSION_MAJOR:STRING=$(shell awk -F= '/^VER_MAJOR/{ print $$2 }' Makefile) \
		-DAPP_VERSION_MINOR:STRING=$(shell awk -F= '/^VER_MINOR/{ print $$2 }' Makefile) \
		-DAPP_VERSION_RELEASE:STRING=$(shell awk -F= '/^VER_RELEASE/{ print $$2 }' Makefile) \
		-DCMAKE_SKIP_BUILD_RPATH=FALSE \
		-DCMAKE_BUILD_WITH_INSTALL_RPATH=FALSE \
		-DCMAKE_INSTALL_RPATH_USE_LINK_PATH=TRUE

override_dh_auto_install:
	dh_auto_install -- PREFIX=/usr
